# === Model Runtime ===
# MODEL_PROVIDER=gemini               # gemini | openai | anthropic | ollama
# MODEL_MODEL=gemini-2.5-flash        # Base/default model
# MODEL_NAV_MODEL=gemini-2.5-flash    # Fast planner model
# MODEL_SYNTH_MODEL=gemini-2.5-pro    # Strong synth model
# MODEL_REVIEW_MODEL=gemini-2.5-pro   # Reserved for evaluator/review features
# MODEL_SYNTH_ENABLED=1               # Enable synth pass on finish
# MODEL_TIMEOUT_MS=120000             # Per-call timeout (ms)

# Gemini credentials
GEMINI_API_KEY=your-gemini-api-key-here

# OpenAI credentials
# MODEL_PROVIDER=openai
# MODEL_API_KEY=sk-...
# MODEL_BASE_URL=https://api.openai.com/v1

# Claude credentials
# MODEL_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# MODEL_BASE_URL=https://api.anthropic.com

# Ollama local runtime
# MODEL_PROVIDER=ollama
# MODEL_BASE_URL=http://127.0.0.1:11434/v1

# Legacy compatibility envs are still accepted:
# OPENAI_COMPAT_API_KEY=
# OPENAI_COMPAT_BASE_URL=http://127.0.0.1:11434/v1

# Legacy Gemini envs are still accepted as fallbacks:
# GEMINI_MODEL=gemini-2.5-flash
# GEMINI_NAV_MODEL=gemini-2.5-flash
# GEMINI_SYNTH_MODEL=gemini-2.5-pro
# GEMINI_REVIEW_MODEL=gemini-2.5-pro
# GEMINI_SYNTH_ENABLED=1
# GEMINI_TIMEOUT_MS=120000

# Claude-specific envs are also accepted as fallbacks:
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001
# ANTHROPIC_NAV_MODEL=claude-haiku-4-5-20251001
# ANTHROPIC_SYNTH_MODEL=claude-sonnet-4-6
# ANTHROPIC_REVIEW_MODEL=claude-sonnet-4-6
# ANTHROPIC_SYNTH_ENABLED=1
# ANTHROPIC_TIMEOUT_MS=120000

# === Browser ===
# CDP_HTTP=http://127.0.0.1:9222  # Chrome DevTools Protocol endpoint
# BROWSER_HEADLESS=false           # true = headless Chromium (auto-launch only)

# === Agent ===
# MAX_STEPS=160               # Max actions per run
# ALLOWED_DOMAINS=            # Comma-separated allowlist (empty = allow all)

# === Storage Paths ===
# RUN_STORE_DIR=./agent_runs

# === Artifacts ===
# CAPTURE_ARTIFACTS=1          # Save DOM snapshots per step
